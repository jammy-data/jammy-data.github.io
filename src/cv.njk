---
layout: base.njk
title: CV
permalink: /cv/
---
<section class="panel reveal">
  <h1>Curriculum Vitae</h1>
  {% if site.cvPath %}
    <p>Use the buttons below to open or download the latest CV.</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="{{ site.cvPath }}" target="_blank" rel="noreferrer">Open CV</a>
      <a class="btn btn-ghost" href="{{ site.cvPath }}" download>Download CV</a>
    </div>
    <p class="meta">If this link fails, confirm the exact filename and case in src/files (for example CV.pdf).</p>
  {% else %}
    <p>CV upload pending.</p>
    <p class="meta">Add your PDF to src/files/CV.pdf and set cvPath in src/_data/site.json to /files/CV.pdf.</p>
  {% endif %}
</section>
