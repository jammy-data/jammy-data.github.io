---
layout: base.njk
title: Home
permalink: /
---
<section class="hero reveal hero-layout">
  <div>
    <p class="eyebrow">Personal Site</p>
    <h1>{{ site.fullName }}</h1>
    <p class="hero-tagline">{{ site.tagline }}</p>
    <p class="hero-copy">{{ site.shortBio }}</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/projects/">View Projects</a>
      <a class="btn btn-ghost" href="/cv/">Open CV</a>
      <a class="btn btn-ghost" href="/about/">About Me</a>
    </div>
  </div>

  {% if site.headshotPath %}
    <div class="hero-media">
      <img class="avatar" src="{{ site.headshotPath }}" alt="Portrait of {{ site.fullName }}">
    </div>
  {% endif %}
</section>

<section class="panel reveal">
  <h2>What I Work On</h2>
  <div class="chip-row">
    {% for tag in collections.projectTags %}
      {% if loop.index <= 10 %}
        <a class="chip chip-link" href="{{ tag.url }}">{{ tag.name }}</a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="panel reveal">
  <h2>Featured Projects</h2>
  {% if collections.featuredProjects.length %}
    {% set homeProjects = collections.featuredProjects %}
  {% else %}
    {% set homeProjects = collections.projects %}
  {% endif %}
  <div class="project-grid">
    {% for project in homeProjects %}
      {% if collections.featuredProjects.length or loop.index <= 3 %}
      {% set projectTags = project.data.keywords or project.data.stack or [] %}
      <article class="project-card">
        <a class="project-thumb-link" href="{{ project.url }}" aria-label="Open {{ project.data.title }}">
          {% if project.data.thumbnail %}
            <img class="project-thumb" src="{{ project.data.thumbnail }}" alt="Thumbnail for {{ project.data.title }}" loading="lazy" decoding="async">
          {% else %}
            <div class="project-thumb project-thumb-fallback" aria-hidden="true"></div>
          {% endif %}
        </a>
        <h3 class="project-title">{{ project.data.title }}</h3>
        <p class="project-summary">{{ project.data.summary }}</p>
        {% if projectTags.length %}
          <div class="chip-row">
            {% for keyword in projectTags %}
              <a class="chip chip-link" href="/projects/tags/{{ keyword | keywordSlug }}/">{{ keyword }}</a>
            {% endfor %}
          </div>
        {% endif %}
        <a class="card-link" href="{{ project.url }}">Read more</a>
      </article>
      {% endif %}
    {% endfor %}
  </div>
</section>
